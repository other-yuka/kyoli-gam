{
  "name": "kyoli-gam-monorepo",
  "private": true,
  "packageManager": "pnpm@10.29.2",
  "workspaces": [
    "packages/*",
    "packages/providers/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "test:contract:native": "pnpm --filter opencode-multi-account-core test:contract:native && pnpm --filter opencode-codex-multi-account test:contract:native && pnpm --filter opencode-anthropic-multi-account test:contract:native",
    "serve": "pnpm --filter @kyoli-gam/cli serve",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:status": "changeset status",
    "release": "pnpm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.29.8",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "turbo": "^2.10.4",
    "vitest": "^4.1.10"
  }
}
