{
  "name": "opencode-anthropic-multi-account",
  "version": "0.2.47",
  "description": "OpenCode plugin for Anthropic multi-account management with automatic rate limit switching",
  "main": "./dist/index.js",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run tests",
    "test:contract:native": "vitest run tests/index.test.ts tests/model/capabilities.test.ts tests/request/tool-adapter.test.ts tests/request/client-adapter.test.ts tests/request/upstream-request.test.ts tests/contract/native-contract-invariants.test.ts tests/request/transform.test.ts tests/runtime/factory.test.ts",
    "test:live:opencode-claude-native": "vitest run tests/live/opencode-claude-native.test.ts",
    "check:fingerprint-drift": "pnpm run build && node scripts/check-live-fingerprint-drift.mjs",
    "check:cc-authorize-probe": "pnpm run build && node scripts/check-cc-authorize-probe.mjs",
    "check:cc-authorize-probe-headless": "node scripts/check-cc-authorize-probe-headless.mjs",
    "bake:fingerprint": "pnpm run build && ALLOW_FINGERPRINT_OVERWRITE=1 node scripts/rebake-bundled-fingerprint.mjs",
    "prepack": "pnpm run build",
    "dev": "tsup --watch",
    "check:sdk-drift": "node scripts/check-sdk-drift.mjs"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "sideEffects": false,
  "keywords": [
    "opencode",
    "plugin",
    "anthropic",
    "claude",
    "multi-account",
    "rate-limit"
  ],
  "author": "yuka",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/other-yuka/kyoli-gam.git",
    "directory": "packages/anthropic-multi-account"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.16.2",
    "opencode-multi-account-core": "workspace:*",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ]
}
