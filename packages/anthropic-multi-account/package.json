{
  "name": "opencode-anthropic-multi-account",
  "version": "0.2.24",
  "description": "OpenCode plugin for Anthropic multi-account management with automatic rate limit switching",
  "main": "./dist/index.js",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "bun test tests",
    "check:fingerprint-drift": "bun run build && node scripts/check-live-fingerprint-drift.mjs",
    "check:cc-authorize-probe": "bun run build && node scripts/check-cc-authorize-probe.mjs",
    "check:cc-authorize-probe-headless": "node scripts/check-cc-authorize-probe-headless.mjs",
    "bake:fingerprint": "bun run build && ALLOW_FINGERPRINT_OVERWRITE=1 node scripts/rebake-bundled-fingerprint.mjs",
    "prepack": "bun run build",
    "dev": "bun run build --watch"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "sideEffects": false,
  "keywords": [
    "opencode",
    "plugin",
    "anthropic",
    "claude",
    "multi-account",
    "rate-limit"
  ],
  "author": "yuka",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/other-yuka/kyoli-gam.git",
    "directory": "packages/anthropic-multi-account"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^0.15.30",
    "opencode-multi-account-core": "^0.2.24",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.2",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ]
}
