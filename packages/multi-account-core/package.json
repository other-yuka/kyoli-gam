{
  "name": "opencode-multi-account-core",
  "version": "0.2.89",
  "description": "Shared core for OpenCode Plugin Mode",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run tests",
    "test:contract:native": "vitest run tests/native-plugin-lifecycle.test.ts tests/native-plugin-auth.test.ts tests/native-plugin-loader.test.ts tests/native-plugin-bootstrap-auth.test.ts tests/native-plugin-models.test.ts",
    "prepack": "pnpm run build",
    "dev": "tsup --watch"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "sideEffects": false,
  "keywords": [
    "opencode",
    "plugin",
    "multi-account",
    "core",
    "shared"
  ],
  "author": "yuka",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/other-yuka/kyoli-gam.git",
    "directory": "packages/multi-account-core"
  },
  "dependencies": {
    "valibot": "^1.4.2"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.17.18",
    "@types/node": "^26.1.1",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ]
}
