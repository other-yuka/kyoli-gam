{
  "name": "@kyoli-gam/provider-codex-chatgpt",
  "version": "0.0.29",
  "private": true,
  "description": "Codex ChatGPT OAuth provider adapter for kyoli-gam v1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./reset-credits": {
      "source": "./src/reset-credits.ts",
      "types": "./dist/reset-credits.d.ts",
      "import": "./dist/reset-credits.js",
      "default": "./dist/reset-credits.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepack": "pnpm run build",
    "dev": "tsup --watch"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "sideEffects": false,
  "author": "yuka",
  "license": "MIT",
  "dependencies": {
    "@kyoli-gam/core": "workspace:*",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/ws": "^8.18.1",
    "typescript": "^6.0.3"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ]
}
