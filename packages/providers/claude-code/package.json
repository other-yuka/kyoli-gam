{
  "name": "@kyoli-gam/provider-claude-code",
  "version": "0.0.37",
  "private": true,
  "description": "Claude Code OAuth provider adapter for kyoli-gam v1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./opencode": {
      "source": "./src/opencode-shared.ts",
      "types": "./dist/opencode-shared.d.ts",
      "import": "./dist/opencode-shared.js",
      "default": "./dist/opencode-shared.js"
    },
    "./fingerprint-data": {
      "source": "./src/fingerprint-data.ts",
      "types": "./dist/fingerprint-data.d.ts",
      "import": "./dist/fingerprint-data.js",
      "default": "./dist/fingerprint-data.js"
    },
    "./fingerprint": {
      "source": "./src/fingerprint-capture.ts",
      "types": "./dist/fingerprint-capture.d.ts",
      "import": "./dist/fingerprint-capture.js",
      "default": "./dist/fingerprint-capture.js"
    },
    "./scrub-template": {
      "source": "./src/scrub-template.ts",
      "types": "./dist/scrub-template.d.ts",
      "import": "./dist/scrub-template.js",
      "default": "./dist/scrub-template.js"
    },
    "./cli-version": {
      "source": "./src/cli-version.ts",
      "types": "./dist/cli-version.d.ts",
      "import": "./dist/cli-version.js",
      "default": "./dist/cli-version.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepack": "pnpm run build",
    "dev": "tsup --watch"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "sideEffects": false,
  "author": "yuka",
  "license": "MIT",
  "dependencies": {
    "@kyoli-gam/core": "workspace:*",
    "opencode-multi-account-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^6.0.3"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ]
}
