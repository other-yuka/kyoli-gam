{
  "name": "@kyoli-gam/gateway",
  "version": "0.0.38",
  "private": true,
  "description": "HTTP gateway for kyoli-gam v1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm run build:server && pnpm run build:dashboard",
    "build:dashboard": "vite build --config vite.dashboard.config.ts",
    "build:server": "tsup",
    "dashboard:dev": "vite --config vite.dashboard.config.ts",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.dashboard.json --noEmit",
    "test": "vitest run",
    "prepack": "pnpm run build",
    "dev": "tsup --watch"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "sideEffects": false,
  "author": "yuka",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/other-yuka/kyoli-gam.git",
    "directory": "packages/gateway"
  },
  "dependencies": {
    "@kyoli-gam/core": "workspace:*",
    "@kyoli-gam/provider-codex-chatgpt": "workspace:*",
    "developer-icons": "^6.0.5",
    "lucide-react": "^1.25.0",
    "motion": "^12.42.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.5"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ]
}
