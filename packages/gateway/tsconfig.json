{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@kyoli-gam/core": ["../core/src/index.ts"],
      "opencode-multi-account-core": ["../multi-account-core/src/index.ts"],
      "@kyoli-gam/model-registry": ["../model-registry/src/index.ts"],
      "@kyoli-gam/provider-codex-chatgpt/reset-credits": ["../providers/codex-chatgpt/src/reset-credits.ts"]
    },
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
