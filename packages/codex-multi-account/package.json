{
  "name": "opencode-codex-multi-account",
  "version": "0.2.34",
  "description": "OpenCode plugin for Codex (OpenAI) multi-account management with automatic rate limit switching",
  "main": "./dist/index.js",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run tests",
    "test:contract:native": "vitest run tests/unsupported-loader.test.ts tests/request-transform.test.ts tests/runtime-factory.test.ts tests/executor.test.ts tests/contract/native-contract.test.ts",
    "prepack": "pnpm run build",
    "dev": "tsup --watch"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "sideEffects": false,
  "keywords": [
    "opencode",
    "plugin",
    "openai",
    "codex",
    "chatgpt",
    "multi-account",
    "rate-limit"
  ],
  "author": "yuka",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/other-yuka/kyoli-gam.git",
    "directory": "packages/codex-multi-account"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.14.48",
    "opencode-multi-account-core": "workspace:*",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.2",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ]
}
